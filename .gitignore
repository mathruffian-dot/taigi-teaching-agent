# 系統與雲端備份暫存
desktop.ini
Thumbs.db
.DS_Store
*.tmp
~$*

# 敏感金鑰與環境變數
.env
.env.*
*.key
credentials.*
secrets.*
config.json


# AI Agent 本地設定檔 (防止 settings.local.json 洩漏 Token)
.claude/
.agents/
.codex/

# 依賴庫
node_modules/
package-lock.json

# 大型模型權重 (請離線部署或放至快取，不提交至 Git)
*.gguf
*.bin
*.pt
*.onnx

# 大型音訊與影像素材 (請上傳至雲端或 YouTube，不提交大型二進位檔)
*.mp4
*.wav
*.mp3
*.webm

# 字體檔 (源石黑體等，可由 ButTaiwan/genseki-font 重新下載，不提交)
*.otf
*.ttf

# 教學影片渲染輸出與旁白音檔 (可由 record.cjs / generate_narration.py 重新產生)
video/**/renders/
video/**/assets/narration/

# Python 虛擬環境
.venv/

# 官方教材下載區（僅供本地研究保存，不隨 repo 散布；來源清單與蒐集流程見
# data/official_materials/sources.json 與 docs/official-materials-workflow.md）
data/official_materials/raw/
data/official_materials/processed/
data/official_materials/analysis/

# 輸出與建置快取
dist/
build/
.cache/
output/
drafts/
__pycache__/
*.pyc

